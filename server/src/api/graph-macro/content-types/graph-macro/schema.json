{
  "kind": "collectionType",
  "collectionName": "graph_macros",
  "info": {
    "singularName": "graph-macro",
    "pluralName": "graph-macros",
    "displayName": "GraphMacro"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "description": {
      "type": "blocks"
    },
    "sortOrder": {
      "type": "integer"
    },
    "keywords": {
      "type": "text",
      "required": true
    },
    "isActive": {
      "type": "boolean",
      "default": true
    },
    "publicationsPrimary": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::publication.publication",
      "mappedBy": "graphMacroPrimary"
    },
    "publicationsTagged": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::publication.publication",
      "inversedBy": "graphMacroTags"
    },
    "mesos": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::graph-meso.graph-meso",
      "mappedBy": "macro"
    }
  }
}
