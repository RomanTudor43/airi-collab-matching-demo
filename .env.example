# =============================================================================
# DATABASE CONFIGURATION (PostgreSQL)
# =============================================================================
# These values must match between the POSTGRES_* and DATABASE_* variables

POSTGRES_USER=strapi
POSTGRES_PASSWORD=strapi
POSTGRES_DB=strapi

DATABASE_CLIENT=postgres
DATABASE_HOST=postgres             
DATABASE_PORT=5432
DATABASE_NAME=strapi
DATABASE_USERNAME=strapi
DATABASE_PASSWORD=strapi

# =============================================================================
# STRAPI CONFIGURATION
# =============================================================================

NODE_ENV=development                # Use 'production' for production deployments

# Server settings
HOST=0.0.0.0
PORT=1337

# Admin panel and internal URLs
STRAPI_ADMIN_URL=/strapi/admin      # Path where admin panel is accessible
STRAPI_INTERNAL_URL=http://strapi:1337  # Internal Docker service URL

# =============================================================================
# STRAPI SECRETS (CHANGE ALL IN PRODUCTION!)
# =============================================================================
# Generate secure random strings for production using:
#   openssl rand -base64 32
# Never commit real secrets to version control!

APP_KEYS="toBeModified1,toBeModified2"
API_TOKEN_SALT=tobemodified
ADMIN_JWT_SECRET=tobemodified
TRANSFER_TOKEN_SALT=tobemodified
JWT_SECRET=tobemodified
ENCRYPTION_KEY=tobemodified

# =============================================================================
# NEXT.JS / FRONTEND CONFIGURATION
# =============================================================================

# Public-facing Strapi URL (used by frontend to fetch data)
# Development: http://localhost:1337
# Production:  https://your-domain.com (no trailing slash)
PUBLIC_STRAPI_URL=http://localhost:1337

# MANDATORY: API token for authenticated requests to Strapi
# Otherwise frontend will not be able to access Strapi at all.
STRAPI_API_TOKEN=changeme_strapi_token

# Redundant for the moment. Will be used for frontend revalidation via Webhooks in the near future.
REVALIDATION_SECRET=changeme_revalidate_secret

# Email address required by the Unpaywall API when looking up PDF URLs.
UNPAYWALL_EMAIL=your-email@example.com

# =============================================================================
# RESEARCH PAPER GRAPH CONFIGURATION
# =============================================================================

# Minimum cosine similarity score to create a link between two papers (0.0 - 1.0)
GRAPH_SIMILARITY_THRESHOLD=0.6

# Papers scoring at or above this threshold are considered duplicates and skipped (0.0 - 1.0)
GRAPH_DUPLICATE_THRESHOLD=0.92

# Sentence-transformer model used to generate paper embeddings
# Again, have to be compatible with "sentence-transformers"
# Ref: https://huggingface.co/models?library=sentence-transformers
GRAPH_AI_MODEL=all-MiniLM-L6-v2

# HDBSCAN (paper-level communities)
# Lower values reduce "noise" points and produce denser clusters.
GRAPH_HDBSCAN_MIN_CLUSTER_SIZE=12
GRAPH_HDBSCAN_MIN_SAMPLES=3

# Distance threshold for assigning secondary community memberships.
# Lower values reduce multi-cluster affiliations.
GRAPH_SECONDARY_CLUSTER_DISTANCE_THRESHOLD=0.7

# HDBSCAN (topic superclusters)
GRAPH_TOPIC_HDBSCAN_MIN_CLUSTER_SIZE=3
GRAPH_TOPIC_HDBSCAN_MIN_SAMPLES=2

# Frontend meso-node shaping (constellation level)
# Small groups below this size are merged into "Other Themes".
GRAPH_MESO_MIN_NODE_PAPERS=3
# Hard cap for number of meso nodes shown in one community view.
GRAPH_MESO_MAX_NODES=20
# Keep at least this many meso nodes before merging small groups.
GRAPH_MESO_MIN_NODES=8

# =============================================================================
# For PROD

REPO_USER=your_github_username
REPO_PASS=your_github_token_with_read_packages_scope